@model List<Empleado>

<h1 class="text-primary">Empleados Almacenados V4</h1>
@if (Model != null)
{
    <table class="table table-striped table-primary">
        <thead>
        <tr>
            <th>Id</th>
            <th>Empleado</th>
            <th>Oficio</th>
            <th>Salario</th>
            <th>Departamento</th>
        </tr>
        </thead>
        <tbody>
        @foreach (Empleado emp in Model)
        {
            <tr>
                <td>@emp.IdEmpleado</td>
                <td>@emp.Apellido</td>
                <td>@emp.Oficio</td>
                <td>@emp.Salario</td>
                <td>@emp.IdDepartamento</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <h2>No hay empleados en Session</h2>
}