@model List<Empleado>

<h1>Session empleados List</h1>

<p>
    <a asp-controller="Empleados"
       asp-action="EmpleadosAlmacenados">
        Empleados Almacenados
    </a>
</p>


<h4>@ViewData["MENSAJE"]</h4>

<ul class="list-group">
    @foreach (Empleado emp in Model)
    {
        <li class="list-group-item list-group-item-warning">
            <a asp-controller="Empleados"
               asp-action="SessionEmpleados"
               asp-route-idempleado="@emp.IdEmpleado">
                Almacenar empleado @emp.Apellido
            </a>
        </li>   
    }
</ul>