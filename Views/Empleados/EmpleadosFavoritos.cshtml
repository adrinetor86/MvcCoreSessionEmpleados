@{
    List<Empleado> favoritos= memoryCache.Get<List<Empleado>>("FAVORITOS");
}
<h1>Empleados Favoritos</h1>


<p>
    <a asp-controller="Empleados"
       asp-action="SessionEmpleadosV5">
        Volver a Empleados 5
    </a>
</p>



@if (favoritos == null)
{
    <h3 class="text-danger">No tenemos empleados favoritos</h3>
}else{
    <table class="table table-striped table-primary">
        <thead>
        <tr>
            <th>Id</th>
            <th>Empleado</th>
            <th>Oficio</th>
            <th>Salario</th>
            <th>Departamento</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var emp in favoritos)
        {
            <tr>
                <td>@emp.IdEmpleado</td>
                <td>@emp.Apellido</td>
                <td>@emp.Oficio</td>
                <td>@emp.Salario</td>
                <td>@emp.IdDepartamento</td>
            </tr>
        }
        </tbody>
    </table>
}