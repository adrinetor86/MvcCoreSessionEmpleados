@model List<Empleado>

<h1 class="text-warning">Empleados Almacenados V5</h1>
@if (Context.Session.GetString("IDSEMPLEADOS")==null)
{
    <h1 style="color: red">No existen empleados en session</h1>
}
@if (Model != null)
{
    <table class="table table-striped table-primary">
        <thead>
        <tr>
            <th>Id</th>
            <th>Empleado</th>
            <th>Oficio</th>
            <th>Salario</th>
            <th>Departamento</th>
            <td>Acciones</td>

        </tr>
        </thead>
        <tbody>
        @foreach (Empleado emp in Model)
        {
            <tr>
                <td>@emp.IdEmpleado</td>
                <td>@emp.Apellido</td>
                <td>@emp.Oficio</td>
                <td>@emp.Salario</td>
                <td>@emp.IdDepartamento</td>
                <td>
                    <a asp-controller="Empleados"
                       asp-action="EmpleadosAlmacenadosV5"
                       asp-route-ideliminar="@emp.IdEmpleado">
                        Eliminar Session
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}