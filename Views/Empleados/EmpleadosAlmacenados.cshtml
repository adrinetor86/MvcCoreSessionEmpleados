
@{
    List<Empleado> empleados= Context.Session.GetObject<List<Empleado>>("EMPLEADOS");
}

@if (empleados != null)
{
    <table class="table table-striped table-primary">
        <thead>
        <tr>
            <th>Id</th>
            <th>Empleado</th>
            <th>Oficio</th>
            <th>Salario</th>
            <th>Departamento</th>
        </tr>
        </thead>
        <tbody>
        @foreach (Empleado emp in empleados)
        {
            <tr>
                <td>@emp.IdEmpleado</td>
                <td>@emp.Apellido</td>
                <td>@emp.Oficio</td>
                <td>@emp.Salario</td>
                <td>@emp.IdDepartamento</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <h2>No hay empleados en Session</h2>
}